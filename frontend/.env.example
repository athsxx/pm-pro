# Build-time API URL (embedded in the JS bundle).
# Use the SAME backend for web and mobile so users, tasks, and auth stay in sync.

# --- Local development ---
# Browser on your Mac:
# VITE_API_BASE=http://localhost:3001

# Android emulator (optional — client.ts already defaults to http://10.0.2.2:3001):
# VITE_API_BASE=http://10.0.2.2:3001

# --- Production (example) ---
# Deploy backend first, then point both web and mobile builds at it:
# VITE_API_BASE=https://api.your-domain.com
