PORT=3001
# ProjectManagementAPP admin API often runs on 3002 locally to avoid clashing with this API on 3001.
# 0.0.0.0 = accept connections from Android emulator (10.0.2.2). Use 127.0.0.1 only if you do not need the emulator.
HOST=0.0.0.0
JWT_SECRET=your_super_secret_key_here
DB_PATH=./pm-pro.db

# Optional: override path to Haynes risk xlsx (default: backend/templates/risk-assessment-haynes.xlsx)
# RISK_TEMPLATE_PATH=/absolute/path/to/risk-assessment-haynes.xlsx

# Default password for seeded POC users (admin1@poc.local, manager1@poc.local, member1–6@poc.local) when the Users table is empty.
POC_DEFAULT_PASSWORD=pocchangeme

# Admin → mobile task mirror (ProjectManagementAPP pushes here). Min 16 chars; same value as PM_PRO_SYNC_SECRET there.
# TASK_SYNC_SECRET=generate_a_long_random_string_here

# Member updates → admin API (same secret as PM_PRO_SYNC_SECRET on admin). Example: http://localhost:3002
# ADMIN_API_URL=http://localhost:3002
